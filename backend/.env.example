PORT=8787

# CORS: Default is permissive (any origin) so standalone web + Vite proxy keep working.
# For Webflow Designer Extension–only API access, set CORS_MODE=strict — then only localhost,
# https://*.webflow-ext.com (unless CORS_ALLOW_WEBFLOW_EXT=false), and CORS_ORIGINS are allowed.
# CORS_MODE=strict
# CORS_ALLOW_WEBFLOW_EXT=false
# CORS_ORIGINS=https://your-subdomain.webflow-ext.com,https://your-marketing-site.com

# Webflow Data Client (OAuth) — copy to `.env` and fill in. Never commit real values.
# Register the app in Workspace → Settings → Apps & Integrations → App Development.
# Redirect URI must match exactly (no trailing slash unless you registered one):
WEBFLOW_CLIENT_ID=
WEBFLOW_CLIENT_SECRET=
WEBFLOW_REDIRECT_URI=http://localhost:8787/api/oauth/webflow/callback

# Space-separated scopes; must be a subset of scopes enabled for the app in the dashboard.
# See: https://developers.webflow.com/data/reference/scopes
WEBFLOW_OAUTH_SCOPES=sites:read authorized_user:read
