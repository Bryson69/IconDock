PORT=8787

# Webflow Data Client (OAuth) — optional unless you call the Webflow Data API from this server.
# Register the app in Workspace → Settings → Apps & Integrations → App Development.
# Redirect URI must match exactly (no trailing slash unless you registered one):
WEBFLOW_CLIENT_ID=
WEBFLOW_CLIENT_SECRET=
WEBFLOW_REDIRECT_URI=http://localhost:8787/api/oauth/webflow/callback

# Space-separated scopes; must be a subset of scopes enabled for the app in the dashboard.
# See: https://developers.webflow.com/data/reference/scopes
WEBFLOW_OAUTH_SCOPES=sites:read authorized_user:read
