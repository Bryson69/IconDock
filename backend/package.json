{
  "name": "icondock-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "build:dataset": "tsx src/iconData/buildDataset.ts",
    "build:dataset:material-fa": "ICONDOCK_LIBRARIES=material,fontawesome tsx src/iconData/buildDataset.ts"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@material-design-icons/svg": "^0.14.15",
    "@material-symbols/svg-400": "^0.43.0",
    "@phosphor-icons/core": "^2.1.1",
    "bootstrap-icons": "^1.11.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "heroicons": "^2.1.5",
    "iconoir": "^7.11.0",
    "lru-cache": "^10.0.2",
    "lucide-static": "^0.469.0",
    "remixicon": "^4.6.0",
    "sharp": "^0.33.4",
    "tslib": "^2.6.3",
    "webflow-api": "^3.3.4"
  },
  "devDependencies": {
    "@types/compression": "^1.7.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
