# When the UI runs inside the Webflow Designer extension iframe, requests cannot use relative /api paths.
# Set this to your deployed IconDock API origin (no trailing slash), e.g.:
# VITE_API_BASE_URL=https://your-api.example.com
#
# Local testing: run the backend on :8787 and point the extension build here:
# VITE_API_BASE_URL=http://localhost:8787
